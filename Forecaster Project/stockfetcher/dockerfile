# Small, reliable base image
FROM python:3.12-slim

# Prevents Python from buffering stdout/stderr (nicer logs in docker)
ENV PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# Install dependencies first (better layer caching)
COPY requirements.txt .
RUN pip install --upgrade pip && pip install -r requirements.txt

# Copy the script
COPY fetch_stocks.py .

# Create an output directory inside the container
RUN mkdir -p /app/outputs

# Default command: run the script
# (If your script writes to current directory, it will write into /app)
CMD ["python", "fetch_stocks.py"]